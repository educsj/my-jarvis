{
  "expo": {
    "name": "Meu Jarvis",
    "slug": "meu-jarvis",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0a0d10",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "O Jarvis usa o microfone para você falar por voz com o assistente."
      }
    },
    "android": {
      "package": "com.eduardocoutinho.meujarvis",
      "permissions": [
        "RECORD_AUDIO",
        "INTERNET"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#0a0d10",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-audio",
        {
          "microphonePermission": "O Jarvis usa o microfone para você falar por voz com o assistente."
        }
      ],
      "expo-asset"
    ]
  }
}
