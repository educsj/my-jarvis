# ---- Banco de Dados (Prisma / SQLite) ----
DATABASE_URL="file:./dev.db"

# ---- Servidor ----
PORT=3333
HOST=0.0.0.0
NODE_ENV=development

# ---- Ollama (Fase 2) ----
OLLAMA_BASE_URL="http://127.0.0.1:11434"
OLLAMA_MODEL="mannix/llama3.1-8b-abliterated:tools-q4_k_m"

# ---- Base de Conhecimento (RAG) ----
KNOWLEDGE_DIR="./knowledge"
EMBED_MODEL="nomic-embed-text"

# ---- Voz: Whisper (STT) e Piper (TTS) ----
# Deixe WHISPER_BIN/PIPER_BIN vazios para usar os stubs simulados.
# Caminhos absolutos para os binários e modelos (ex.: em C:\jarvis-voice\...).
FFMPEG_BIN="ffmpeg"
WHISPER_BIN=""
WHISPER_MODEL=""
WHISPER_LANG="pt"
PIPER_BIN=""
PIPER_MODEL=""

# ---- Google Calendar OAuth2 (Fase 3) ----
# Nunca versione credentials.json / token.json
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3333/auth/google/callback"
